# Anthropic API (for AI-generated fixes)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Custom Search API (for competitor discovery - future)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# Site URL for sharing (required for share buttons)
NEXT_PUBLIC_SITE_URL=https://thecommoditytest.com

# Vercel sets this automatically in production
VERCEL_URL=your-app.vercel.app

# Contact form - Email via Resend (https://resend.com - free tier available)
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
NOTIFICATION_EMAIL=hi@leefuhr.com
# FROM_EMAIL requires verified domain in Resend, defaults to contact@thecommoditytest.com
FROM_EMAIL=contact@thecommoditytest.com

# Contact form - Storage via Vercel KV (auto-populated when deployed)
# These are set automatically by Vercel when you add KV from the dashboard
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
