# Anthropic API (for AI-generated fixes)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Custom Search API (for competitor discovery - future)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# Site URL for sharing (required for share buttons)
NEXT_PUBLIC_SITE_URL=https://thecommoditytest.com

# Vercel sets this automatically in production
VERCEL_URL=your-app.vercel.app
