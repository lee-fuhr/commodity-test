# Shared environment variables for LFI tools
# Copy to each tool's .env.local and fill in

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe (payments)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Anthropic (AI analysis)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Vercel (storage - get from Vercel dashboard after deploy)
KV_REST_API_URL=https://xxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxx
BLOB_READ_WRITE_TOKEN=xxxxxxxxxxxx
